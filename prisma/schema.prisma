generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  VENDOR
  CUSTOMER
}

enum AccountStatus {
  ACTIVE
  PENDING
  SUSPENDED
  DISABLED
}

enum VendorStatus {
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  CHANGES_REQUESTED
  ACTIVE
  REJECTED
  ARCHIVED
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
  BACKORDER
}

enum OrderStatus {
  PENDING
  PROCESSING
  READY_FOR_DISPATCH
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
}

enum RefundStatus {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  PROCESSED
}

enum WithdrawalStatus {
  REQUESTED
  APPROVED
  PROCESSING
  PAID
  REJECTED
  CANCELLED
  REVERSED
}

enum PayoutMethod {
  BANK_TRANSFER
  EASYPAISA
  JAZZCASH
  PAYPAL
}

enum CommissionType {
  PERCENTAGE_OF_SALE
  FIXED_AMOUNT
  VENDOR_VOLUME_PERCENTAGE
  PRODUCT_PRICE_RANGE_PERCENTAGE
}

enum CouponType {
  PERCENTAGE
  FIXED
  FREE_SHIPPING
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum TicketStatus {
  OPEN
  PENDING_VENDOR
  PENDING_CUSTOMER
  RESOLVED
  CLOSED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum LedgerEntryType {
  CREDIT
  DEBIT
}

enum ShippingMethodType {
  FLAT_RATE
  FREE_SHIPPING
  LOCAL_PICKUP
  DISTANCE_RATE
}

enum NotificationType {
  ORDER
  VENDOR
  REFUND
  WITHDRAWAL
  REVIEW
  SUPPORT
  SYSTEM
}

model User {
  id               String           @id @default(cuid())
  name             String
  email            String           @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  role             UserRole         @default(CUSTOMER)
  status           AccountStatus    @default(ACTIVE)
  phone            String?
  rememberToken    String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  accounts         Account[]
  sessions         Session[]
  vendorProfile    VendorProfile?
  customerProfile  CustomerProfile?
  addresses        Address[]
  orders           Order[]          @relation("CustomerOrders")
  reviews          Review[]
  reviewVotes      ReviewVote[]
  reviewReports    ReviewReport[]
  wishlistItems    Wishlist[]
  refundRequests   RefundRequest[]
  couponUsages     CouponUsage[]
  notifications    Notification[]
  sentMessages     Message[]        @relation("SentMessages")
  receivedMessages Message[]        @relation("ReceivedMessages")
  supportTickets   SupportTicket[]
  activityLogs     ActivityLog[]
}

model Role {
  id          String   @id @default(cuid())
  key         UserRole @unique
  name        String
  description String?
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CustomerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VendorProfile {
  id                 String               @id @default(cuid())
  userId             String               @unique
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  status             VendorStatus         @default(PENDING_APPROVAL)
  approvedAt         DateTime?
  rejectedAt         DateTime?
  suspendedAt        DateTime?
  internalNotes      String?
  verificationBadge  Boolean              @default(false)
  bankName           String?
  accountTitle       String?
  accountNumber      String?
  iban               String?
  commissionType     CommissionType?
  commissionValue    Decimal?             @db.Decimal(12, 2)
  store              Store?
  products           Product[]
  orders             OrderItem[]
  withdrawals        Withdrawal[]
  ledgerEntries      VendorLedgerEntry[]
  subscriptions      VendorSubscription[]
  commissionHistory  CommissionHistory[]
  refundRequests     RefundRequest[]
  couponRestrictions CouponVendor[]
  ownedCoupons       Coupon[]             @relation("VendorOwnedCoupons")
  trustScore         VendorTrustScore?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

model Store {
  id             String          @id @default(cuid())
  vendorId       String          @unique
  vendor         VendorProfile   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name           String
  slug           String          @unique
  description    String?
  logoUrl        String?
  bannerUrl      String?
  address        String?
  phone          String?
  email          String?
  seoTitle       String?
  seoDescription String?
  returnPolicy   String?
  shippingPolicy String?
  paymentPolicy  String?
  hours          Json?
  vacationMode   Boolean         @default(false)
  inquiryEnabled Boolean         @default(true)
  products       Product[]
  reviews        Review[]
  categories     StoreCategory[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model StoreCategory {
  id         String   @id @default(cuid())
  storeId    String
  categoryId String
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([storeId, categoryId])
}

model MembershipPlan {
  id               String               @id @default(cuid())
  name             String
  slug             String               @unique
  description      String?
  priceMonthly     Decimal              @default(0) @db.Decimal(12, 2)
  priceYearly      Decimal              @default(0) @db.Decimal(12, 2)
  maxProducts      Int?
  commissionRate   Decimal              @default(10) @db.Decimal(5, 2)
  featuredListings Boolean              @default(false)
  prioritySupport  Boolean              @default(false)
  trialDays        Int                  @default(0)
  features         Json?
  subscriptions    VendorSubscription[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model VendorSubscription {
  id        String             @id @default(cuid())
  vendorId  String
  planId    String
  vendor    VendorProfile      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  plan      MembershipPlan     @relation(fields: [planId], references: [id])
  status    SubscriptionStatus @default(TRIAL)
  startsAt  DateTime           @default(now())
  expiresAt DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model Category {
  id                 String           @id @default(cuid())
  name               String
  slug               String           @unique
  parentId           String?
  parent             Category?        @relation("CategoryTree", fields: [parentId], references: [id])
  children           Category[]       @relation("CategoryTree")
  commissionType     CommissionType?
  commissionValue    Decimal?         @db.Decimal(12, 2)
  products           Product[]
  storeCategories    StoreCategory[]
  couponRestrictions CouponCategory[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Brand {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  logoUrl   String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id                 String           @id @default(cuid())
  vendorId           String
  storeId            String
  categoryId         String?
  brandId            String?
  vendor             VendorProfile    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  store              Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category           Category?        @relation(fields: [categoryId], references: [id])
  brand              Brand?           @relation(fields: [brandId], references: [id])
  name               String
  slug               String           @unique
  sku                String?          @unique
  barcode            String?
  shortDescription   String?
  description        String
  tags               String[]
  price              Decimal          @db.Decimal(12, 2)
  salePrice          Decimal?         @db.Decimal(12, 2)
  costPrice          Decimal?         @db.Decimal(12, 2)
  taxRate            Decimal?         @db.Decimal(5, 2)
  stock              Int              @default(0)
  lowStockThreshold  Int              @default(5)
  stockStatus        StockStatus      @default(IN_STOCK)
  trackInventory     Boolean          @default(true)
  weight             Decimal?         @db.Decimal(10, 2)
  length             Decimal?         @db.Decimal(10, 2)
  width              Decimal?         @db.Decimal(10, 2)
  height             Decimal?         @db.Decimal(10, 2)
  shippingType       String           @default("paid")
  videoUrl           String?
  viewCount          Int              @default(0)
  seoTitle           String?
  seoDescription     String?
  seoKeywords        String?
  status             ProductStatus    @default(DRAFT)
  featured           Boolean          @default(false)
  rejectionReason    String?
  adminNote          String?
  commissionType     CommissionType?
  commissionValue    Decimal?         @db.Decimal(12, 2)
  images             ProductImage[]
  variants           ProductVariant[]
  orderItems         OrderItem[]
  reviews            Review[]
  wishlistItems      Wishlist[]
  couponRestrictions CouponProduct[]
  inventoryLogs      InventoryLog[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([vendorId])
  @@index([storeId])
  @@index([categoryId])
  @@index([status])
}

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  name       String
  sku        String?     @unique
  options    Json
  price      Decimal?    @db.Decimal(12, 2)
  salePrice  Decimal?    @db.Decimal(12, 2)
  stock      Int         @default(0)
  imageUrl   String?
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model InventoryLog {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  change    Int
  reason    String
  note      String?
  actorId   String?
  createdAt DateTime @default(now())
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int     @default(0)
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String?
  line1      String
  line2      String?
  city       String
  region     String?
  postalCode String?
  country    String  @default("Pakistan")
  orders     Order[] @relation("ShippingAddress")
}

model Order {
  id                String          @id @default(cuid())
  orderNumber       String          @unique
  customerId        String
  shippingAddressId String?
  customer          User            @relation("CustomerOrders", fields: [customerId], references: [id])
  shippingAddress   Address?        @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  status            OrderStatus     @default(PENDING)
  paymentStatus     PaymentStatus   @default(PENDING)
  subtotal          Decimal         @db.Decimal(12, 2)
  discountTotal     Decimal         @default(0) @db.Decimal(12, 2)
  shippingTotal     Decimal         @default(0) @db.Decimal(12, 2)
  taxTotal          Decimal         @default(0) @db.Decimal(12, 2)
  grandTotal        Decimal         @db.Decimal(12, 2)
  notes             String?
  trackingNumber    String?
  trackingUrl       String?
  estimatedDelivery DateTime?
  deliveredAt       DateTime?
  cancelledAt       DateTime?
  items             OrderItem[]
  payments          Payment[]
  transactions      Transaction[]
  refundRequests    RefundRequest[]
  timeline          OrderTimeline[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([status])
  @@index([paymentStatus])
  @@index([customerId])
}

model OrderItem {
  id              String          @id @default(cuid())
  orderId         String
  productId       String
  variantId       String?
  vendorId        String
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product         @relation(fields: [productId], references: [id])
  variant         ProductVariant? @relation(fields: [variantId], references: [id])
  vendor          VendorProfile   @relation(fields: [vendorId], references: [id])
  name            String
  sku             String?
  quantity        Int
  unitPrice       Decimal         @db.Decimal(12, 2)
  discountTotal   Decimal         @default(0) @db.Decimal(12, 2)
  taxTotal        Decimal         @default(0) @db.Decimal(12, 2)
  shippingTotal   Decimal         @default(0) @db.Decimal(12, 2)
  lineTotal       Decimal         @db.Decimal(12, 2)
  commissionTotal Decimal         @default(0) @db.Decimal(12, 2)
  refundRequests  RefundRequest[]
  review          Review?

  @@index([vendorId])
}

model Payment {
  id             String        @id @default(cuid())
  orderId        String
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider       String
  method         String
  status         PaymentStatus @default(PENDING)
  amount         Decimal       @db.Decimal(12, 2)
  transactionRef String?
  rawResponse    Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Transaction {
  id          String   @id @default(cuid())
  orderId     String?
  order       Order?   @relation(fields: [orderId], references: [id])
  vendorId    String?
  type        String
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())
}

model OrderTimeline {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    String
  note      String?
  actorId   String?
  createdAt DateTime @default(now())
}

model RefundRequest {
  id            String         @id @default(cuid())
  orderId       String
  orderItemId   String?
  customerId    String
  vendorId      String?
  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem     OrderItem?     @relation(fields: [orderItemId], references: [id])
  customer      User           @relation(fields: [customerId], references: [id])
  vendor        VendorProfile? @relation(fields: [vendorId], references: [id])
  amount        Decimal        @db.Decimal(12, 2)
  isPartial     Boolean        @default(false)
  reason        String
  adminDecision String?
  status        RefundStatus   @default(REQUESTED)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Dispute {
  id          String       @id @default(cuid())
  orderId     String
  customerId  String
  vendorId    String
  subject     String
  description String
  status      TicketStatus @default(OPEN)
  resolution  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Withdrawal {
  id                String           @id @default(cuid())
  vendorId          String
  vendor            VendorProfile    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  amount            Decimal          @db.Decimal(12, 2)
  method            PayoutMethod
  status            WithdrawalStatus @default(REQUESTED)
  initiatedByAdmin  Boolean          @default(false)
  adminNote         String?
  requestedAt       DateTime         @default(now())
  processedAt       DateTime?
  paidAt            DateTime?
  rejectionReason   String?
  reference         String?

  @@index([vendorId])
  @@index([status])
}

model VendorLedgerEntry {
  id          String          @id @default(cuid())
  vendorId    String
  vendor      VendorProfile   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  type        LedgerEntryType
  amount      Decimal         @db.Decimal(12, 2)
  source      String
  description String?
  balance     Decimal         @db.Decimal(12, 2)
  createdAt   DateTime        @default(now())
}

model CommissionHistory {
  id                   String         @id @default(cuid())
  vendorId             String
  orderItemId          String?
  vendor               VendorProfile  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  type                 CommissionType
  rateOrAmount         Decimal        @db.Decimal(12, 2)
  commissionOnShipping Boolean        @default(false)
  commissionOnTax      Boolean        @default(false)
  couponDeducted       Boolean        @default(true)
  calculatedAmount     Decimal        @db.Decimal(12, 2)
  createdAt            DateTime       @default(now())
}

model Coupon {
  id             String           @id @default(cuid())
  code           String           @unique
  name           String
  type           CouponType
  value          Decimal          @db.Decimal(12, 2)
  usageLimit     Int?
  usedCount      Int              @default(0)
  minOrderAmount Decimal?         @db.Decimal(12, 2)
  startsAt       DateTime?
  expiresAt      DateTime?
  active         Boolean          @default(true)
  vendorId       String?
  vendor         VendorProfile?   @relation("VendorOwnedCoupons", fields: [vendorId], references: [id], onDelete: SetNull)
  products       CouponProduct[]
  categories     CouponCategory[]
  vendors        CouponVendor[]
  usages         CouponUsage[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model CouponProduct {
  id        String  @id @default(cuid())
  couponId  String
  productId String
  coupon    Coupon  @relation(fields: [couponId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([couponId, productId])
}

model CouponCategory {
  id         String   @id @default(cuid())
  couponId   String
  categoryId String
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([couponId, categoryId])
}

model CouponVendor {
  id       String        @id @default(cuid())
  couponId String
  vendorId String
  coupon   Coupon        @relation(fields: [couponId], references: [id], onDelete: Cascade)
  vendor   VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([couponId, vendorId])
}

model CouponUsage {
  id       String   @id @default(cuid())
  couponId String
  userId   String
  orderId  String?
  coupon   Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])
  usedAt   DateTime @default(now())
}

model Review {
  id              String        @id @default(cuid())
  userId          String
  productId       String?
  storeId         String?
  orderItemId     String?       @unique
  title           String?
  rating          Int
  comment         String?
  status          ReviewStatus  @default(PENDING)
  flagged         Boolean       @default(false)
  verifiedPurchase Boolean      @default(false)
  helpfulCount    Int           @default(0)
  reportCount     Int           @default(0)
  vendorReply     String?
  vendorRepliedAt DateTime?
  editedAt        DateTime?
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  product         Product?      @relation(fields: [productId], references: [id], onDelete: Cascade)
  store           Store?        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItem       OrderItem?    @relation(fields: [orderItemId], references: [id])
  images          ReviewImage[]
  votes           ReviewVote[]
  reports         ReviewReport[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([productId])
  @@index([userId])
  @@index([status])
}

model ReviewImage {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  createdAt DateTime @default(now())
}

model ReviewVote {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String
  helpful   Boolean
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
}

model ReviewReport {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String
  reason    String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
}

model VendorTrustScore {
  id                  String        @id @default(cuid())
  vendorId            String        @unique
  vendor              VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  overallScore        Float         @default(0)
  avgRating           Float         @default(0)
  totalReviews        Int           @default(0)
  verifiedReviews     Int           @default(0)
  positivePercent     Float         @default(0)
  orderCompletionRate Float         @default(0)
  refundRate          Float         @default(0)
  responseRate        Float         @default(0)
  deliveryScore       Float         @default(0)
  badges              String[]
  lastCalculated      DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Banner {
  id        String    @id @default(cuid())
  title     String
  imageUrl  String
  linkUrl   String?
  placement String
  active    Boolean   @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model SupportTicket {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendorId    String?
  subject     String
  description String
  status      TicketStatus @default(OPEN)
  priority    String       @default("normal")
  messages    Message[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Message {
  id         String         @id @default(cuid())
  senderId   String
  receiverId String?
  ticketId   String?
  sender     User           @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User?          @relation("ReceivedMessages", fields: [receiverId], references: [id])
  ticket     SupportTicket? @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  body       String
  readAt     DateTime?
  createdAt  DateTime       @default(now())
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())
}

model Settings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  group       String
  updatedAt   DateTime @updatedAt
}

model AnalyticsSnapshot {
  id        String   @id @default(cuid())
  scope     String
  period    String
  metrics   Json
  createdAt DateTime @default(now())
}

model ShippingZone {
  id        String           @id @default(cuid())
  name      String
  countries Json
  regions   Json?
  cities    Json?
  methods   ShippingMethod[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model ShippingMethod {
  id                 String             @id @default(cuid())
  zoneId             String
  zone               ShippingZone       @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  name               String
  type               ShippingMethodType
  rate               Decimal            @default(0) @db.Decimal(12, 2)
  vendorsCanOverride Boolean            @default(false)
  active             Boolean            @default(true)
}

model ShippingClass {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  minWeight   Decimal? @db.Decimal(10, 2)
  maxWeight   Decimal? @db.Decimal(10, 2)
}

model ShipmentTrackingProvider {
  id        String   @id @default(cuid())
  name      String
  apiKey    String?
  endpoint  String?
  active    Boolean  @default(false)
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
